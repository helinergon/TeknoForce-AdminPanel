@page
@model TeknoForce.Pages.Dashboard.IndexModel


@{
    ViewBag.title = "TeknoForce.Admin";
}
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
}

@section styles {
    <link href="/libs/jsvectormap/jsvectormap.min.css" rel="stylesheet"/>
}


<div class="row justify-content-center">
    <div class="row g-4">

        <!-- Toplam Ürün -->
        <div class="col-md-6 col-lg-3">
            <div class="card dashboard-card">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <p class="card-title">Toplam Ürün</p>
                        <h3>@Model.ProductCount</h3>
                    </div>
                    <div class="icon-circle">
                        <i class="fa-solid fa-box"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Toplam Sipariş -->
        <div class="col-md-6 col-lg-3">
            <div class="card dashboard-card">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <p class="card-title">Toplam Sipariş</p>
                        <h3>@Model.OrderCount</h3>
                    </div>
                    <div class="icon-circle">
                        <i class="fa fa-cart-arrow-down"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bekleyen Yorum -->
        <div class="col-md-6 col-lg-3">
            <div class="card dashboard-card">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <p class="card-title">Onay Bekleyen Yorum</p>
                        <h3>@Model.PendingCommentCount</h3>
                    </div>
                    <div class="icon-circle">
                        <i class="fa fa-commenting"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Toplam Ciro -->
        <div class="col-md-6 col-lg-3">
            <div class="card dashboard-card">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <p class="card-title">Toplam Ciro</p>
                        <h3 class="mt-2 mb-0 fw-bold">@Model.TotalRevenue ₺</h3>
                    </div>
                    <div class="icon-circle">
                        <i class="fa fa-line-chart"></i>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Son 5 Sipariş</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Müşteri</th>
                                    <th>Tarih</th>
                                    <th>Tutar</th>
                                    <th>Durum</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.LastOrders.Any())
                                {
                                    foreach (var order in Model.LastOrders)
                                    {
                                        <tr>
                                            <td>@order.OrderId</td>
                                            <td>@order.OrderNumber</td>
                                            <td>@order.CreatedDate.ToString("dd.MM.yyyy")</td>
                                            <td>@order.TotalAmount ₺</td>
                                            <td>
                                                @if (order.OrderStatus != null)
                                                {
                                                    <span class="badge"
                                                          style="background:@order.OrderStatus.ColorCode">
                                                        @order.OrderStatus.Name
                                                    </span>
                                                }

                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted">
                                            Henüz sipariş yok.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Sipariş Durum Dağılımı</h5>
                </div>
                <div class="card-body">
                    <canvas id="orderStatusChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    @section scripts {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

        <script>
            const ctx = document.getElementById('orderStatusChart');

            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.OrderStatusLabels)),
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(Model.OrderStatusCounts)),
                    }]
                }
            });
        </script>
    }

 </div>
