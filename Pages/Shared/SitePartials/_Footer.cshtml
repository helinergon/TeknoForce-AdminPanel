@inject TeknoForce.Data.AppDbContext _context

<section class="branches__section py-5">
    <div class="container">
        <div class="section__heading text-center mb-50">
            <h2 class="section__heading--title custom-title">Şubelerimiz</h2>
            <h2 class="display-6 fw-bold color-primary">Size en yakın noktada hizmet vermeye hazırız.</h2>
        </div>

        <div class="row align-items-stretch g-4">
            @{
                var branches = _context.ContactBranches.Where(x => x.IsActive).ToList();
            }

            @foreach (var branch in branches)
            {
                <div class="col-lg-6 mb-4">
                    <div class="branch__card h-100 d-flex flex-column">
                        <div class="branch__header">
                            <div class="branch__title-box">
                                <h4 class="fw-bold mb-0">@branch.ContactName</h4>
                                <span class="location-tag">
                                    <i class="bi bi-geo-alt-fill"></i> @branch.Address
                                </span>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(branch.MapIframe))
                        {
                            <div class="branch__map-container mt-3">
                                @Html.Raw(branch.MapIframe)
                            </div>
                        }

                        <div class="branch__contact-list mt-auto pt-4">
                            <h6 class="contact-header mb-3"><i class="bi bi-telephone-outbound me-2"></i>İletişim Bilgileri</h6>

                            @{
                                var phones = _context.ContactPhones
                                .Where(p => p.ContactBranchId == branch.ContactBranchId && p.IsActive)
                                .OrderBy(p => p.SortOrder)
                                .ToList();
                            }

                            <div class="modern-contact-grid">
                                @foreach (var phone in phones)
                                {
                                    <div class="contact-line-item">
                                        <div class="contact-info-left">
                                            <span class="contact-label">@phone.label</span>
                                            <a href="tel:@phone.PhoneNumber" class="contact-number">@phone.PhoneNumber</a>
                                        </div>
                                        <div class="contact-action-right">
                                            <a href="tel:@phone.PhoneNumber" class="btn-call-icon">
                                                <i class="bi bi-telephone"></i>
                                            </a>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

        <section class="social__section py-5">
            <div class="container">
                <div class="text-center mb-5">
                    <h2 class="display-6 fw-bold color-primary">Bizi Takip Edin</h2>
                    <p class="lead text-muted">Teknolojilerimizi ve videolarımızı sosyal medyada keşfedin!</p>
                </div>

                <div class="row g-4 justify-content-center">
                    <div class="col-lg-4 col-md-6">
                        <a href="https://www.instagram.com/boyamateknolojileri" target="_blank" class="custom-social-card insta">
                            <div class="social-icon-box">
                                <i class="bi bi-instagram"></i>
                            </div>
                            <div class="social-text-box">
                                <span class="platform">Instagram</span>
                                <span class="handle">boyamateknolojileri</span>
                            </div>
                        </a>
                    </div>

                    <div class="col-lg-4 col-md-6">
                        <a href="https://www.tiktok.com/@@xforce_boyamakinalari" target="_blank" class="custom-social-card tiktok">
                            <div class="social-icon-box">
                                <i class="bi bi-tiktok"></i>
                            </div>
                            <div class="social-text-box">
                                <span class="platform">TikTok</span>
                                <span class="handle">xforce_boyamakinalari</span>
                            </div>
                        </a>
                    </div>

                    <div class="col-lg-4 col-md-6">
                        <a href="https://www.facebook.com/share/18TWhrENy5/" target="_blank" class="custom-social-card face">
                            <div class="social-icon-box">
                                <i class="bi bi-facebook"></i>
                            </div>
                            <div class="social-text-box">
                                <span class="platform">Facebook</span>
                                <span class="handle">X-Force Boya Makinaları</span>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </section>


 

    <style>

    /* İletişim Rehberi Konteynırı */
    .modern-contact-grid {
        display: grid;
        grid-template-columns: 1fr 1fr; /* Numaraları 2 sütun yapar, ferahlatır */
        gap: 15px;
    }

    /* Her Bir Satır (Item) Tasarımı */
    .contact-line-item {
        background: #fcfcfc;
        border: 1px solid #f0f0f0;
        border-radius: 12px;
        padding: 12px 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: 0.3s ease;
    }

        .contact-line-item:hover {
            background: #ffffff;
            border-color: #ff7a00; /* Marka turuncusu ile etkileşim */
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }

    /* Yazı Stilleri */
    .contact-label {
        display: block;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        color: #999;
        letter-spacing: 0.5px;
        margin-bottom: 2px;
    }

    .contact-number {
        font-size: 1rem;
        font-weight: 600;
        color: #1a237e; /* Kurumsal Lacivert */
        text-decoration: none !important;
    }

    /* Küçük Arama Butonu */
    .btn-call-icon {
        width: 32px;
        height: 32px;
        background: #eef2ff;
        color: #1a237e;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        transition: 0.3s;
    }

    .contact-line-item:hover .btn-call-icon {
        background: #ff7a00;
        color: white;
    }

    /* Mobilde tek sütuna düşür */
    @@media (max-width: 768px) {
        .modern-contact-grid {
            grid-template-columns: 1fr;
        }
    }

    /* Ana Kart Tasarımı */
    .modern-branch-card {
        background: #ffffff;
        border-radius: 30px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.04);
        border: 1px solid rgba(0,0,0,0.05);
        transition: all 0.4s ease;
    }

        .modern-branch-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(26, 35, 126, 0.08);
        }

    /* Harita Düzenlemesi */
    .map-wrapper iframe {
        width: 100% !important;
        height: 300px !important;
        filter: grayscale(0.2); /* Haritayı biraz daha kurumsal gösterir */
    }

    /* Başlık Şeridi */
    .heading-line {
        width: 60px;
        height: 4px;
        background: #ff7a00;
        border-radius: 2px;
    }

    /* Haritaya Git Butonu */
    .btn-map-link {
        font-size: 0.85rem;
        font-weight: 700;
        color: #1a237e;
        text-decoration: none;
        padding: 8px 16px;
        border: 1px solid #e0e0e0;
        border-radius: 50px;
        transition: 0.3s;
    }

        .btn-map-link:hover {
            background: #1a237e;
            color: white !important;
        }

    /* İletişim Grid Sistemi - MAVİ KUTULARA VEDA */
    .contact-flex-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    .minimal-contact-item {
        padding: 12px 15px;
        border-bottom: 1px solid #f0f0f0; /* Sadece ince bir çizgi */
        display: flex;
        flex-direction: column;
    }

    .staff-name {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        color: #999;
        letter-spacing: 0.5px;
    }

    .staff-phone {
        font-size: 1rem;
        font-weight: 600;
        color: #333;
        text-decoration: none;
        transition: 0.2s;
    }

        .staff-phone:hover {
            color: #ff7a00; /* Sadece üzerine gelince numara turuncu olsun */
        }

    .contact-header-minimal {
        font-size: 0.8rem;
        font-weight: 800;
        color: #1a237e;
        letter-spacing: 1px;
        opacity: 0.6;
    }














        .custom-social-card {
            display: flex;
            align-items: center;
            background: #ffffff !important; /* Beyaz arka planı zorunlu kıldık */
            padding: 25px;
            border-radius: 20px;
            text-decoration: none !important;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08); /* Güçlü gölge */
            border: 1px solid rgba(0,0,0,0.05);
            transition: all 0.3s ease;
        }

        .social-icon-box {
            width: 60px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            border-radius: 15px;
            margin-right: 20px;
        }

        /* Platforma Özel Renkler */
        .insta .social-icon-box {
            background: #fff0f5;
            color: #d6249f;
        }

        .tiktok .social-icon-box {
            background: #f5f5f5;
            color: #000;
        }

        .face .social-icon-box {
            background: #e7f3ff;
            color: #1877f2;
        }

        .social-text-box {
            display: flex;
            flex-direction: column;
        }

        .platform {
            font-size: 1.4rem; /* Yazıları büyüttük */
            font-weight: 800;
            color: #1a237e;
            line-height: 1.1;
        }

        .handle {
            font-size: 1rem;
            color: #6c757d;
        }

        /* Üzerine gelince efekt */
        .custom-social-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.12);
        }

        .color-primary {
            color: #1a237e;
        }
    </style>
