                height: 4px;
                background: #ff7a00;
                margin: 10px auto 0;
            }
        /* Hero Section - Yükseklik ve Konumlandırma */
        .hero__section {
            position: relative;
            /* Yüksekliği tam ekrandan (100vh) yarım ekrana (50vh) düşürdük */
            min-height: 50vh;
            display: flex;
            align-items: center;
            overflow: hidden;
            /* Arka plan rengini (gri) kaldırdık ki video görünsün */
            background: none !important;
        }

        /* Video Konteyneri - Tam Kaplama */
        .video-background {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0; /* En arka katman */
        }

            .video-background video {
                width: 100%;
                height: 100%;
                object-fit: cover; /* Videoyu boşluk kalmayacak şekilde yayar */
            }

        /* Karartma Katmanı - Yazı Okunabilirliği İçin */
        .hero__bg--overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            /* Hafif karanlık bir gradyan ekleyelim */
            background: linear-gradient(90deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 100%);
            z-index: 1; /* Videonun hemen önünde */
        }

        /* İçerik Katmanı - En Önde */
        .container.position-relative {
            /* Yazıların ve butonların videonun önünde görünmesi için z-index verdik */
            z-index: 2 !important;
        }

        /* Yazı Renkleri ve Stilleri */
        .hero__title {
            color: #ffffff !important; /* Başlık beyaz olsun */
