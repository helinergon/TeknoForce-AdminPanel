            transform: translateY(-10px);
            box-shadow: 0 10px 25px rgba(26, 35, 126, 0.15);
        }

            .category-custom-card:hover .card-img-box img {
                transform: scale(1.1);
            }

            .category-custom-card:hover .category-name {
