            }

        .card-img-top {
            height: 200px;
            object-fit: contain; /* Resmi bozmadan kutuya sığdırır */
            padding: 15px;
            background: #fff;
        }
        
        /* Kart Tasarımı */
        

        /* Görsel Alanı */
        .card-img-box {
            height: 200px;
            overflow: hidden;
            border-bottom: 1px solid #eee;
        }

            .card-img-box img {
                width: 100%;
                height: 100%;
                object-fit: cover; /* Kolajları kutuya tam oturtur */
                transition: transform 0.5s ease;
            }

        /* İçerik Alanı */
        .card-content {
            padding: 20px;
        }

        .category-name {
