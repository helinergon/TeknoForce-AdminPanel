        }

        /* Görsel Şölen CSS Dokunuşları */
        :root {
            --primary-orange: #ff7a00;
            --dark-navy: #0f172a;
            --text-gradient: linear-gradient(90deg, #ff7a00, #ffb300);
        }

        .text-gradient {
            background: var(--text-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }


        h2.section-title {
            position: relative;
            color: #1a237e;
            font-weight: 800;
            text-transform: uppercase;
            margin-bottom: 40px;
            text-align: center;
        }

            h2.section-title::after {
                content: '';
