@{
    string currentPath = Context.Request.Path.Value?.ToLower() ?? "";
    Func<string, string> isActive = (path) =>
        {
            path = path.ToLower();
            return currentPath == path || currentPath.StartsWith(path + "/")
            ? "active"
            : "";
        };
    }

  

@*
    ADMIN LAYOUT
    Login hariç tüm admin sayfalar bunu kullanır
*@
<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - TeknoForce Admin</title>

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- CSS -->
    <link href="/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #fff4ec, #ffe8d8);
        }

        .table td,
        .table th {
            padding: 25px 25px;
        }

        .admin-card {
            background: #ffffff;
            padding: 25px;
            border-radius: 18px;
            box-shadow: 0 10px 25px rgba(21, 12, 133, 0.08);
        }


        /* SIDEBAR */
        .sidebar {
            width: 250px;
            background: #150c85; 
            color: #fff;
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            padding-top: 20px;
            overflow-y:auto;
        }

        .sidebar {
            background: linear-gradient(180deg, #150c85, #1d129f);
        }

        .status {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 14px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 600;
        }

            .status.active {
                background: #e7f8ef;
                color: #1e7f43;
            }

            .status.passive {
                background: #fdeaea;
                color: #b42318;
            }

        .status-badge {
            padding: 6px 14px;
            border-radius: 999px;
            background: #fff0e6;
            color: #ff8a00;
            font-size: 13px;
            font-weight: 600;
        }

        .dashboard-card {
            border: none;
            border-radius: 18px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.05);
            transition: 0.3s;
        }

            .dashboard-card:hover {
                transform: translateY(-5px);
            }

            .dashboard-card .card-title {
                font-size: 14px;
                color: #6b7280;
                margin-bottom: 4px;
            }

            .dashboard-card h3 {
                font-weight: 700;
                color: #150c85;
            }


        .icon-circle {
            width: 55px;
            height: 55px;
            background: linear-gradient(135deg,#ff8a00,#ffb347);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            font-size: 20px;
        }


        .update-time {
            font-size: 12px;
            color: #6b7280;
        }

        table tbody tr:hover {
            background-color: #f9fafb;
        }

        .form-control {
            border-radius: 12px;
            border: 1px solid #eee;
            padding: 10px 14px;
        }

            .form-control:focus {
                border-color: #ff8a00;
                box-shadow: 0 0 0 0.2rem rgba(255,138,0,.15);
            }


            .sidebar .logo {
                text-align: center;
                font-size: 29px;
                font-weight: 1000;
                color: #ff8a00;
                margin-bottom: 32px;
               
            }

            .sidebar a {
                display: block;
                padding: 12px 20px;
                color: #DEB887;
                text-decoration: none;
                font-size: 15px;
            }

                .sidebar a:hover {
                    background: #150c85;
                    color: #ff8a00;
                }

            .sidebar .menu-title {
                padding: 10px 20px;
                font-size: 12px;
                text-transform: uppercase;
                color: #ff8a00;
                margin-top: 15px;
            }

            .sidebar a.active {
                background: linear-gradient(90deg, #ff8a00, #ff9a8a);
                color: #150c85;
                font-weight: 600;
                border-radius: 6px;
                margin: 4px 8px;
            }

        /* TOPBAR */
        .topbar {
            height: 60px;
            background: #ffffff;
            border-bottom: 1px solid #e5e7eb;
            padding: 0 20px;
            margin-left: 250px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

            .topbar .title {
                font-weight: 600;
                color: #150c85;
            }

        /* CONTENT */
   

        .table {
            background: #ffffff;
            border-radius: 16px;
            overflow: hidden;
        }

            .table thead {
                background-color: #ffe5d6;
                font-weight: 600;
            }

            .table tbody tr:hover {
                background-color: #fff1e8;
            }
    

                .table thead th {
                    color: #150c85;
                    font-weight: 600;
                }


        .card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(21,12,133,0.08);
            transition: 0.3s ease;
        }

            .card:hover {
                transform: translateY(-6px);
            }

            .card h3 {
                color: #150c85;
            }

            .card .icon {
                background: linear-gradient(90deg,#ff8a00,#ffb347);
                color: white;
            }



        .content {
            margin-left: 250px;
            padding: 30px;
            padding-top: 90px;
        }

        .logout-btn {
            color: #dc3545;
            font-weight: 600;
            padding: 6px 12px;
            border-radius: 8px;
            transition: all 0.2s ease;
        }

            .logout-btn:hover {
                background: #fdeaea;
                color: #b42318;
            }




        .btn {
            background: linear-gradient(90deg, #ff8a00, #ffb347);
            border: none;
            color: #fff;
            border-radius: 12px;
            padding: 8px 18px;
            font-weight: 600;
            transition: all 0.25s ease;
        }

            .btn:hover {
                background: linear-gradient(90deg, #150c85, #2b1fd1);
                color: #fff;
                transform: translateY(-2px);
                box-shadow: 0 8px 18px rgba(21, 12, 133, 0.25);
            }

            .btn:active {
                transform: scale(0.97);
                box-shadow: none;
            }

        .btn-sm {
            border-radius: 10px;
        }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="logo">TEKNOFORCE</div>

        <div class="menu-title">Dashboard</div>
        <a href="/Dashboard/Index" class="@isActive("/dashboard")">
            <i class="fa-solid fa-chart-line me-2"></i>İstatistikler
            </a>

        <div class="menu-title">Katalog</div>
        <a href="/Brands" class="@isActive("/brands")">
            <i class="fa-solid fa-industry me-2"></i>Markalar
            </a>

        <a href="/Categories" class="@isActive("/categories")">
            <i class="fa-solid fa-layer-group me-2"></i>Kategoriler
            </a>

        <a href="/Products" class="@isActive("/products")">
            <i class="fa-solid fa-box me-2"></i>Ürünler
            </a>

        <div class="menu-title">İçerik Yönetimi</div>
        <a href="/About" class="@isActive("/about")">
            <i class="fa-solid fa-circle-info me-2"></i>Hakkımızda
            </a>

        <a href="/Contact/Branches" class="@isActive("/contact")">
            <i class="fa-solid fa-envelope me-2"></i>İletişim
            </a>

        <a href="/Reviews" class="@isActive("/reviews")">
            <i class="fa-solid fa-star me-2"></i>Yorumlar
            </a>

        <div class="menu-title">Sipariş Yönetimi</div>
        <a href="/Orders" class="@isActive("/orders")">
            <i class="fa-solid fa-cart-shopping me-2"></i>Siparişler
            </a>

        <a href="/OrderStatuses" class="@isActive("/orderstatuses")">
            <i class="fa-solid fa-flag me-2"></i>Sipariş Durumları
            </a>

        <div class="menu-title">Ayarlar</div>
        <a href="/Settings" class="@isActive("/settings")">
            <i class="fa-solid fa-gear me-2"></i>Site Ayarları
            </a>
    </div>

    <!-- TOPBAR -->
    <div class="topbar">
        <div class="title">@ViewData["Title"]</div>
        <div>
            <a href="/Auth/Logout" class="logout-btn">
                <i class="fa-solid fa-right-from-bracket"></i> Çıkış
            </a>
        </div>
    </div>

    <!-- CONTENT -->
    <div class="content">
        @RenderBody()
    </div>
    @RenderSection("styles", required: false)
    @RenderSection("scripts", required: false)
</body>


</html>
