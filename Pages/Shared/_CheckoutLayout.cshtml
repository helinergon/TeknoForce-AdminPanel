@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - TeknoForce</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        /* Tasarımın tam oturması için eklediğim özel CSS */
        body {
            background-color: #f8f9fa;
        }

        .checkout-card, .summary-card {
            background: white;
            border-radius: 15px;
            border: 1px solid #eee;
        }

        .form-control {
            padding: 0.75rem;
            border-radius: 10px;
        }

        .btn-primary {
            background-color: #002d72; /* TeknoForce Laciverti */
            border: none;
            padding: 12px;
            transition: 0.3s;
        }

            .btn-primary:hover {
                background-color: #ff7a00;
            }
        /* Hover'da Turuncu */
    </style>
</head>
<body>

    <!-- Minimal Header -->
    <div class="container py-3 d-flex justify-content-between align-items-center">
        <a asp-page="/Index">
            <img src="~/uploads/brands/teknoforce logo.png"
                 style="height:50px;" />
        </a>

        <span class="fw-bold">Güvenli Sipariş</span>
    </div>

    <hr />

    <div class="container">
        @RenderBody()
    </div>

</body>
</html>