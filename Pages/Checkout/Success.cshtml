@page
@model TeknoForce.Pages.Checkout.SuccessModel
@{
    Layout = "_CheckoutLayout";
}

<div class="success-wrapper py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 text-center">
                <div class="mb-5">
                    <div class="success-icon shadow-sm mb-4">
                        <i class="bi bi-check-all display-1 text-white"></i>
                    </div>
                    <h2 class="fw-bold text-dark">Siparişiniz Başarıyla Alındı!🎉</h2>
                    <p class="text-muted fs-5">Bizi tercih ettiğiniz için teşekkür ederiz.</p>
                </div>

                <div class="order-number-card p-3 mb-4 rounded-4 bg-white border shadow-sm d-inline-block px-5">
                    <span class="text-muted d-block small uppercase fw-bold">Sipariş Numaranız</span>
                    <span class="fs-3 fw-bold text-primary">#@Model.OrderNumber</span>
                </div>

                <div class="bank-details-container text-start mt-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-bank me-2 text-primary"></i> Havale / EFT Bilgileri</h5>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="bank-card p-4 rounded-4 bg-white border shadow-sm h-100">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h6 class="fw-bold mb-0 text-dark">Garanti Bankası</h6>
                                    <i class="bi bi-shield-check text-success"></i>
                                </div>
                                <div class="bank-info mb-2">
                                    <small class="text-muted d-block">Alıcı:</small>
                                    <span class="fw-bold small">X FORCE BOYAMA TEKNOLOJİLERİ SAN. VE TİC. LTD. ŞTİ.</span>
                                </div>
                                <div class="iban-box p-2 bg-light rounded border mt-2 position-relative">
                                    <small class="text-muted d-block" style="font-size: 0.7rem;">IBAN:</small>
                                    <code class="text-dark fw-bold">TR88 0006 2000 4360 0006 2937 12</code>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="bank-card p-4 rounded-4 bg-white border shadow-sm h-100">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h6 class="fw-bold mb-0 text-dark">Kuveyt Türk</h6>
                                    <i class="bi bi-shield-check text-success"></i>
                                </div>
                                <div class="bank-info mb-2">
                                    <small class="text-muted d-block">Alıcı:</small>
                                    <span class="fw-bold small">X FORCE BOYAMA TEKNOLOJİLERİ SAN. VE TİC. LTD. ŞTİ.</span>
                                </div>
                                <div class="iban-box p-2 bg-light rounded border mt-2">
                                    <small class="text-muted d-block" style="font-size: 0.7rem;">IBAN:</small>
                                    <code class="text-dark fw-bold">TR09 0020 5000 0983 6069 2000 01</code>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-warning border-0 rounded-4 p-4 mt-4 shadow-sm d-flex align-items-center">
                        <i class="bi bi-exclamation-triangle-fill fs-3 me-3"></i>
                        <div>
                            <strong>Önemli Not:</strong> Lütfen transferi yaparken açıklama kısmına sadece
                            <span class="badge bg-dark fs-6">@Model.OrderNumber</span>
                            yazınız. Bu, siparişinizin onaylanma sürecini hızlandıracaktır.
                        </div>
                    </div>
                </div>

                <div class="mt-5">
                    <a asp-page="/Index" class="btn btn-outline-primary btn-lg rounded-pill px-5 me-2">
                        <i class="bi bi-house-door me-2"></i>Ana Sayfaya Dön
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .success-wrapper {
        background-color: #fcfcfc;
        min-height: 90vh;
    }

    .success-icon {
        width: 120px;
        height: 120px;
        background: linear-gradient(45deg, #002d72, #ff7a00);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
    }

    .bank-card {
        transition: 0.3s;
        border-left: 4px solid #002d72 !important;
    }

        .bank-card:hover {
            transform: translateY(-5px);
        }

    code {
        font-family: 'Courier New', Courier, monospace;
        font-size: 0.9rem;
        word-break: break-all;
    }

    .order-number-card {
        border-top: 3px solid #ff7a00 !important;
    }
</style>